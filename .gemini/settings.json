{
  "theme": "Default",
  "selectedAuthType": "oauth-personal",
  "mcpServers": {
    "filesystem": {
      "command": "bash",
      "args": [
        "servers/filesystem/run.sh"
      ],
      "env": {}
    },
    "puppeteer": {
      "command": "bash",
      "args": [
        "servers/puppeteer/run.sh"
      ],
      "env": {
        "PUPPETEER_LAUNCH_OPTIONS": "{\"args\": [\"--no-sandbox\"]}",
        "ALLOW_DANGEROUS": "true"
      }
    }
  }
}